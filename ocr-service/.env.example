# Token ini wajib sama dengan OCR_SERVICE_TOKEN
# pada file .env utama Laravel.
OCR_SERVICE_TOKEN=GANTI_DENGAN_TOKEN_RANDOM_64_KARAKTER

# Maksimal ukuran file: 10 MiB.
OCR_MAX_UPLOAD_SIZE=10485760

# Kuitansi dibatasi satu halaman agar pemrosesan CPU stabil.
OCR_MAX_PDF_PAGES=1

# Konfigurasi render PDF dan gambar.
OCR_PDF_DPI=144
OCR_MAX_IMAGE_SIDE=1280

# Optimasi CPU.
OCR_ENABLE_MKLDNN=true
OCR_CPU_THREADS=4
OCR_RECOGNITION_BATCH_SIZE=4

# Batas pemrosesan OCR.
# Untuk tahap pertama disamakan dengan konfigurasi proyek saat ini.
OCR_HARD_TIMEOUT_SECONDS=95
